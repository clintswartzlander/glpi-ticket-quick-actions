{
  "name": "clintswartzlander/glpi-ticket-quick-actions",
  "description": "Secure quick actions for GLPI 11 ticket pages",
  "type": "glpi-plugin",
  "license": "GPL-3.0-or-later",
  "require": {
    "php": ">=8.2"
  },
  "autoload": {
    "psr-4": {
